{
  "name": "mathning",
  "private": true,
  "main": "apps/index.ts",
  "workspaces": [
    "apps",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w @mathning/shared",
    "start": "expo start ./apps",
    "start:clear": "expo start ./apps --clear",
    "android": "expo start ./apps --android",
    "ios": "expo start ./apps --ios",
    "dev:mobile": "npm run build:shared && expo start ./apps"
  }
}
